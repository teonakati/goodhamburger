@page "/products/create"
@page "/products/edit/{Id:int}"
@rendermode InteractiveServer
@inject ApiClient Api
@inject NavigationManager Nav

<PageTitle>@(Id == 0 ? "New Product" : "Edit Product")</PageTitle>
<h3>@(Id == 0 ? "New Product" : "Edit Product")</h3>

@if (error is not null)
{
    <div class="alert alert-danger">@error</div>
}

<EditForm Model="model" OnValidSubmit="Submit" class="mt-3" style="max-width:480px">
    <DataAnnotationsValidator />
    <ValidationSummary class="text-danger" />

    <div class="mb-3">
        <label class="form-label">Name</label>
        <InputText class="form-control" @bind-Value="model.Name" />
    </div>

    <div class="mb-3">
        <label class="form-label">Price</label>
        <InputNumber class="form-control" @bind-Value="model.Price" />
    </div>

    <div class="mb-3">
        <label class="form-label">Type</label>
        <InputSelect class="form-select" @bind-Value="model.Type">
            @foreach (var t in Enum.GetValues<ProductType>())
            {
                <option value="@t">@t</option>
            }
        </InputSelect>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a href="/products" class="btn btn-secondary ms-2">Cancel</a>
</EditForm>

@code {
    [Parameter] public int Id { get; set; }

    private FormModel model = new();
    private string? error;

    protected override async Task OnParametersSetAsync()
    {
        if (Id == 0) return;

        var product = await Api.GetProductAsync(Id);
        if (product is null) { Nav.NavigateTo("/products"); return; }

        model.Name  = product.Name;
        model.Price = product.Price;
        model.Type  = product.Type;
    }

    private async Task Submit()
    {
        var dto = new CreateProductDto(model.Name, model.Price, model.Type);

        var res = Id == 0
            ? await Api.CreateProductAsync(dto)
            : await Api.UpdateProductAsync(Id, dto);

        if (res.IsSuccessStatusCode) Nav.NavigateTo("/products");
        else error = await res.Content.ReadAsStringAsync();
    }

    private class FormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        public string Name { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Range(0.01, 99999)]
        public decimal Price { get; set; }

        public ProductType Type { get; set; } = ProductType.Sandwich;
    }
}
